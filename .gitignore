# Ignore Terraform working directories in all subfolders
**/.terraform/*

# Ignore Terraform state files everywhere
**/*.tfstate
**/*.tfstate.*

# Ignore crash logs
**/crash.log

# Ignore override files
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json

# Ignore plan files
**/*.tfplan

# Ignore variable files (often contain secrets)
**/*.tfvars
**/*.tfvars.json

# Ignore CLI config files
.terraformrc
terraform.rc
